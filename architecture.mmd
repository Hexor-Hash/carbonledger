flowchart TD
    %% Define subnets or groups
    subgraph Frontend[Frontend]
        direction TB
        NextJS[Next.js 14]
    end

    subgraph Backend[Backend]
        direction TB
        NestJS[NestJS]
    end

    subgraph Database[Database]
        direction TB
        PostgreSQL[PostgreSQL]
        Redis[Redis]
    end

    subgraph Storage[Storage]
        direction TB
        IPFS[IPFS]
    end

    subgraph Blockchain[Blockchain]
        direction TB
        Stellar[Stellar Network]
        Soroban[Soroban Contracts]
    end

    subgraph Oracle[Oracle Services]
        direction TB
        Python[Python Oracle Services]
    end

    %% Connections
    Frontend -->|HTTP/HTTPS| Backend
    Backend -->|Prisma ORM| PostgreSQL
    Backend -->|Redis Client| Redis
    Backend -->|IPFS API (Pinata)| IPFS
    Backend -->|Stellar SDK| Stellar
    Stellar -->|Contract Calls| Soroban
    Oracle -->|Stellar SDK (py-stellar-base)| Stellar
    Oracle -->|Database Driver| PostgreSQL
    Oracle -->|HTTP/Webhooks| ExternalServices[External Services (Satellite, Price Feeds)]
    Backend -->|Reads Oracle Data| PostgreSQL
    Frontend -->|Stellar SDK (@stellar/stellar-sdk, freighter)| Stellar
    Frontend -->|Wallet API (Freighter)| Stellar

    %% Style classes
    classDef frontend fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef backend fill:#fff3e0,stroke:#ef6c00,stroke-width:2px;
    classDef database fill:#e8f5e8,stroke:#2e7d32,stroke-width:2px;
    classDef storage fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px;
    classDef blockchain fill:#ffebee,stroke:#c62828,stroke-width:2px;
    classDef oracle fill:#e0f2f1,stroke:#00695c,stroke-width:2px;
    classDef external fill:#fafafa,stroke:#9e9e9e,stroke-width:2px;

    class NextJS frontend;
    class NestJS backend;
    class PostgreSQL,Redis database;
    class IPFS storage;
    class Stellar,Soroban blockchain;
    class Python oracle;
    class ExternalServices external;